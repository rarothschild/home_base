---
interface Props {
	title: string;
}

const { title } = Astro.props;
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from "@vercel/speed-insights/astro"

import Hexagon from '../components/Hexagon.astro';
import '../styles/global.css';

const currentPath = Astro.url.pathname;
const navLinks = [
	{ href: '/', label: 'Home', match: (path: string) => path === '/' },
	{ href: '/resume', label: 'Resume', match: (path: string) => path.startsWith('/resume') },
];

// Hexagon bacground props
const rows = 4
const cols = 40
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Rob Rothschild – systems & software engineer building data analytics tools, scientific computing, simulation dashboards, and other endeauvers. Explore portfolio projects, resume/cv, and contact links."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon-32x32.png" />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
			crossorigin="anonymous"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Rob Rothschild – Systems & Software Engineer</title>
		<meta property="og:site_name" content="Rob Rothschild Portfolio" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title + ' | Rob Rothschild – Systems & Software Engineer'} />
		<meta
			property="og:description"
			content="Portfolio of systems & software engineer Rob Rothschild"
		/>
		<meta property="og:url" content={Astro.url.toString()} />
		<meta property="og:image" content="https://www.robrothschild.com/images/JWST_Pic.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title + ' | Rob Rothschild – Systems & Software Engineer'} />
		<meta
			name="twitter:description"
			content="Portfolio of systems & software engineer Rob Rothschild"
		/>
	</head>
	<body class="relative overflow-x-clip">
		<div class="flex flex-col pb-4 md:pt-6 w-full overflow-y-auto 
					absolute left-1/2 transform -translate-x-1/2 max-w-5xl 
					text-white z-10">
			<!-- Header -->
			<header class="flex justify-between w-full mb-2 md:mb-0">
				<!-- Name & Nav -->
				<div class="flex items-end justify-between w-full gap-4 md:gap-6">
					<h1 class="font-bold text-2xl md:text-4xl text-black" style="font-family: Verdana, Geneva, sans-serif;">Rob Rothschild</h1>
					<!-- Desktop Nav -->
					<nav class="nav-shell">
						{navLinks.map((link) => {
							const isActive = link.match(currentPath);
							return (
								<a
									href={link.href}
									class={`nav-link ${isActive ? 'nav-link-active' : ''}`}
									aria-current={isActive ? 'page' : undefined}
								>
									{link.label}
								</a>
							);
						})}
					</nav>
					<!-- Icons -->
					<div class="hidden md:flex gap-2 pb-1">
						<a href="https://github.com/rarothschild" class="w-6 h-6">
							<span class="icon "><i class="fab fa-github fa-xl"></i></span>
						</a>
						<a href="https://www.linkedin.com/in/rob-rothschild/" class="flex button is-small is-linkedin">
							<span class="icon"><i class="fab fa-linkedin fa-xl"></i></span>
						</a>
						<a href="https://www.instagram.com/rothschild.robert/" class="flex button is-small is-instagram">
							<span class="icon"><i class="fab fa-instagram fa-xl"></i></span>
						</a>
					</div>
				</div>
				<!-- Mobile hamburger + icons -->
				<div class="flex items-center justify-end gap-3 md:hidden mt-2">
					<div class="flex gap-2">
						<a href="" class="w-5 h-5">
							<span class="icon "><i class="fab fa-github"></i></span>
						</a>
						<a href="" class="w-5 h-5">
							<span class="icon"><i class="fab fa-linkedin"></i></span>
						</a>
						<a href="" class="w-5 h-5">
							<span class="icon"><i class="fab fa-instagram"></i></span>
						</a>
					</div>
					<button
						type="button"
						class="inline-flex items-center justify-center p-2 panel-1 hover:bg-gray-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-stone-800 focus:ring-white"
						aria-controls="mobile-menu"
						aria-expanded="false"
						onclick="const m = document.getElementById('mobile-menu'); if (m) { const isHidden = m.classList.contains('hidden'); m.classList.toggle('hidden'); this.setAttribute('aria-expanded', isHidden ? 'true' : 'false'); }"
					>
						<span class="sr-only">Open main menu</span>
						<svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</div>
			</header>
			<!-- Mobile menu -->
			<nav
				id="mobile-menu"
				class="md:hidden my-2 border-2 border-zinc-300 bg-stone-900/95 backdrop-blur-sm hidden"
			>
				<ul class="flex flex-col">
					{navLinks.map((link) => {
						const isActive = link.match(currentPath);
						return (
							<li>
								<a
									href={link.href}
									class={`mobile-nav-link ${isActive ? 'mobile-nav-link-active' : ''}`}
									aria-current={isActive ? 'page' : undefined}
								>
									{link.label}
								</a>
							</li>
						);
					})}
				</ul>
			</nav>
			<!-- Content -->
			<main class="w-full z-10">
				<slot />
			</main>
		</div>
		<!-- Hex grid background -->
		<div class="hex-grid fixed z-0 bottom-[-2rem] left-[-5rem]">
			{Array.from({ length: rows }).map((_, rowIndex) => (
				<div class={`hex-row ${rowIndex % 2 !== 0 ? 'offset' : ''}`}>
				{Array.from({ length: cols }).map(() => (
					<Hexagon />
				))}
				</div>
			))}
		</div>
		<SpeedInsights/>
	</body>
</html>
