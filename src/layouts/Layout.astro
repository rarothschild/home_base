---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

import Hexagon from '../components/Hexagon.astro';
import defaultSocialImage from '../images/JWST_Pic.png';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	imageAlt?: string;
}

const {
	title,
	description = 'Rob Rothschild builds simulation, analytics, and web tools for engineering and test systems.',
	image,
	imageAlt = 'Rob Rothschild standing with teammates beside the James Webb Space Telescope during testing.',
} = Astro.props;

const siteTitle = 'Rob Rothschild';
const pageTitle = `${title} | ${siteTitle} – Systems & Software Engineer`;
const siteBase = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, siteBase).toString();
const socialImageUrl = new URL(image ?? defaultSocialImage.src, siteBase).toString();
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const navLinks = [
	{ href: '/', label: 'Home', match: (path: string) => path === '/' },
	{ href: '/resume', label: 'Resume', match: (path: string) => path === '/resume' || path.startsWith('/resume/') },
];
const socialLinks = [
	{ href: 'https://github.com/rarothschild', label: 'GitHub', shortLabel: 'GH' },
	{ href: 'https://www.linkedin.com/in/rob-rothschild/', label: 'LinkedIn', shortLabel: 'LI' },
	{ href: 'https://www.instagram.com/rothschild.robert/', label: 'Instagram', shortLabel: 'IG' },
];

// Hexagon background props
const rows = 4;
const cols = 40;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="author" content="Rob Rothschild" />
		<meta name="theme-color" content="#d15d49" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" type="image/png" href="/favicon-32x32.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta property="og:site_name" content="Rob Rothschild Portfolio" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content={imageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta name="twitter:image:alt" content={imageAlt} />
	</head>
	<body class="relative overflow-x-clip">
		<div class="flex flex-col pb-4 md:pt-6 w-full overflow-y-auto 
					absolute left-1/2 transform -translate-x-1/2 max-w-5xl px-3 md:px-0 
					text-white z-10">
			<!-- Header -->
			<header class="flex justify-between w-full mb-2 md:mb-0">
				<!-- Name & Nav -->
				<div class="flex items-end justify-between w-full gap-4 md:gap-6">
					<a href="/" class="font-bold text-2xl md:text-4xl text-black tracking-tight" style="font-family: Verdana, Geneva, sans-serif;">Rob Rothschild</a>
					<!-- Desktop Nav -->
					<nav class="nav-shell" aria-label="Primary">
						{navLinks.map((link) => {
							const isActive = link.match(currentPath);
							return (
								<a
									href={link.href}
									class={`nav-link ${isActive ? 'nav-link-active' : ''}`}
									aria-current={isActive ? 'page' : undefined}
								>
									{link.label}
								</a>
							);
						})}
					</nav>
					<!-- Social links -->
					<div class="hidden md:flex gap-2 pb-1">
						{socialLinks.map((link) => (
							<a
								href={link.href}
								target="_blank"
								rel="me noopener noreferrer"
								class="rounded-full border border-stone-950/20 bg-white/75 px-3 py-1 text-sm font-semibold text-stone-900 transition-colors hover:bg-white"
								aria-label={link.label}
							>
								{link.label}
							</a>
						))}
					</div>
				</div>
				<!-- Mobile hamburger + social links -->
				<div class="flex items-center justify-end gap-3 md:hidden mt-2">
					<div class="flex gap-2">
						{socialLinks.map((link) => (
							<a
								href={link.href}
								target="_blank"
								rel="me noopener noreferrer"
								class="rounded-full border border-zinc-200/70 bg-stone-900/80 px-2.5 py-1 text-xs font-semibold text-stone-100"
								aria-label={link.label}
							>
								{link.shortLabel}
							</a>
						))}
					</div>
					<button
						type="button"
						class="inline-flex items-center justify-center p-2 panel-1 hover:bg-gray-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-stone-800 focus:ring-white"
						aria-controls="mobile-menu"
						aria-expanded="false"
						data-mobile-menu-button
					>
						<span class="sr-only">Open main menu</span>
						<svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</div>
			</header>
			<!-- Mobile menu -->
			<nav
				id="mobile-menu"
				class="md:hidden my-2 border-2 border-zinc-300 bg-stone-900/95 backdrop-blur-sm hidden"
				aria-label="Mobile navigation"
			>
				<ul class="flex flex-col">
					{navLinks.map((link) => {
						const isActive = link.match(currentPath);
						return (
							<li>
								<a
									href={link.href}
									class={`mobile-nav-link ${isActive ? 'mobile-nav-link-active' : ''}`}
									aria-current={isActive ? 'page' : undefined}
								>
									{link.label}
								</a>
							</li>
						);
					})}
				</ul>
			</nav>
			<!-- Content -->
			<main class="w-full z-10">
				<slot />
			</main>
		</div>
		<!-- Hex grid background -->
		<div class="hex-grid fixed z-0 bottom-[-2rem] left-[-5rem]">
			{Array.from({ length: rows }).map((_, rowIndex) => (
				<div class={`hex-row ${rowIndex % 2 !== 0 ? 'offset' : ''}`}>
				{Array.from({ length: cols }).map(() => (
					<Hexagon />
				))}
				</div>
			))}
		</div>
		<script>
			const menuButton = document.querySelector('[data-mobile-menu-button]');
			const mobileMenu = document.getElementById('mobile-menu');

			if (menuButton instanceof HTMLButtonElement && mobileMenu) {
				const closeMenu = () => {
					mobileMenu.classList.add('hidden');
					menuButton.setAttribute('aria-expanded', 'false');
				};

				menuButton.addEventListener('click', () => {
					const isHidden = mobileMenu.classList.contains('hidden');
					mobileMenu.classList.toggle('hidden');
					menuButton.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
				});

				mobileMenu.querySelectorAll('a').forEach((link) => {
					link.addEventListener('click', closeMenu);
				});
			}
		</script>
		<Analytics />
		<SpeedInsights/>
	</body>
</html>
